# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_search_console_verification_token
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_google_analytics_measurement_id

# Lemon Squeezy Configuration
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_signing_secret
NEXT_PUBLIC_LEMONSQUEEZY_MONTHLY_VARIANT_ID=your_monthly_variant_id
NEXT_PUBLIC_LEMONSQUEEZY_YEARLY_VARIANT_ID=your_yearly_variant_id

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_KEY_1=your_gemini_key_1
GEMINI_KEY_2=your_gemini_key_2
GEMINI_KEY_3=your_gemini_key_3
GEMINI_KEY_4=your_gemini_key_4
GEMINI_KEY_5=your_gemini_key_5
GEMINI_KEY_6=your_gemini_key_6
GEMINI_KEY_7=your_gemini_key_7
GEMINI_KEY_8=your_gemini_key_8
GEMINI_KEY_9=your_gemini_key_9
GEMINI_KEY_10=your_gemini_key_10
NEXT_PUBLIC_ENABLE_SEARCH_GROUNDING=false

# Pollinations image generation
POLLINATIONS_API_KEY=your_pollinations_api_key

# Scheduled publishing
CRON_SECRET=replace_with_a_long_random_secret
WEBHOOK_SIGNING_SECRET=replace_with_a_separate_long_random_secret
PUBLISH_MOCK_MODE=true

# Google Search Console is authorized through the Google provider configured in Supabase Auth.
# Add https://www.googleapis.com/auth/webmasters.readonly to the provider's allowed scopes.

# Direct social integrations
SOCIAL_TOKEN_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
